# Copy to .env and update for your environment

PORT=3000

# Postgres connection string for Prisma
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/backend?schema=public"

# Google AI Studio / Gemini API key (intent classification)
GEMINI_API_KEY=

# API key required on every request (x-api-key or Authorization: Bearer ...)
API_KEY=

# Integration tests (optional): copy .env.test.example → .env.test; Postgres must be running (`npm test`).

# Optional; defaults to gemini-2.5-flash-lite (cheapest stable text tier on the pricing page).
# GEMINI_MODEL=gemini-2.5-flash-lite

# End-of-day email digest (POST /internal/daily-digest, protected by CRON_SECRET)
# Digest uses UTC calendar days; schedule cron e.g. just after midnight UTC.
# CRON_SECRET=
# RESEND_API_KEY=
# EMAIL_FROM="Language Coach <onboarding@yourdomain.com>"

# Optional: SMS nudge for learners without email (daily digest cron; same UTC day as digest)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# Telegram Bot — use either webhook OR long polling, not both.
# TELEGRAM_BOT_TOKEN=
# Webhook: POST /telegram/webhook (optional TELEGRAM_WEBHOOK_SECRET)
# TELEGRAM_WEBHOOK_SECRET=
# Long polling: getUpdates in-process (good for local dev; clears webhook on startup)
# TELEGRAM_LONG_POLLING=false
# Long-poll interval in seconds (0–50; default 25 — shorter is often more stable via Docker/VPN)
# TELEGRAM_LONG_POLL_TIMEOUT=25


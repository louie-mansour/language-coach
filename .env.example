# Copy to .env and update for your environment

PORT=3000

# Postgres connection string for Prisma
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/backend?schema=public"

# Google AI Studio / Gemini API key (intent classification)
GEMINI_API_KEY=

# API key required on every request (x-api-key or Authorization: Bearer ...)
API_KEY=

# Integration tests (optional): copy .env.test.example → .env.test; Postgres must be running (`npm test`).

# Optional; defaults to gemini-2.5-flash-lite (cheapest stable text tier on the pricing page).
# GEMINI_MODEL=gemini-2.5-flash-lite


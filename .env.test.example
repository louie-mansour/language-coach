# Optional: copy to .env.test for overrides (see vitest.config.ts).
#
# Recommended: run `make test` — it starts compose Postgres if needed, creates DB
# languagecoach_test, and sets DATABASE_URL for that DB only (your dev DB is untouched).
#
# Manual `pnpm test` without Make: point at the isolated DB, same credentials as docker-compose.yml:
# DATABASE_URL="postgresql://languagecoach:languagecoach@127.0.0.1:5432/languagecoach_test"

# Optional overrides (defaults are set in vitest.config.ts if unset)
# API_KEY=test-api-key-integration
# GEMINI_API_KEY=test-gemini-key
# GEMINI_MODEL=gemini-2.5-flash-lite
